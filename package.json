{
  "name": "sad-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "dev:platform": "npm run dev --workspace=apps/platform",
    "build:platform": "npm run build --workspace=apps/platform",
    "build:all": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspace=apps/web",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
